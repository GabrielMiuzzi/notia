{
  "name": "notia",
  "private": true,
  "version": "1.0.1-ALPHA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "./scripts/tauri-cli.sh",
    "dev:tauri": "./scripts/tauri-dev-linux.sh",
    "dev:tauri:linux": "./scripts/tauri-dev-linux.sh",
    "dev:tauri:auto": "./scripts/tauri-dev-linux.sh",
    "dev:tauri:wayland": "NOTIA_TAURI_BACKEND=wayland NOTIA_TAURI_FALLBACK_X11=0 ./scripts/tauri-dev-linux.sh",
    "dev:tauri:wayland:fallback": "NOTIA_TAURI_BACKEND=wayland NOTIA_TAURI_FALLBACK_X11=1 ./scripts/tauri-dev-linux.sh",
    "dev:android": "NDK_HOME=\"$(ls -d \"$HOME\"/Android/Sdk/ndk/* 2>/dev/null | sort -V | tail -1)\" ANDROID_NDK_HOME=\"$(ls -d \"$HOME\"/Android/Sdk/ndk/* 2>/dev/null | sort -V | tail -1)\" tauri android dev --open",
    "build:android:debug": "./scripts/tauri-cli.sh android build --apk --debug --target aarch64",
    "build:android:release": "./scripts/android-build-release.sh",
    "build:android:aab": "./scripts/android-build-release.sh --aab",
    "install:android:release": "./scripts/android-install-release.sh",
    "dev:tauri:x11": "NOTIA_TAURI_BACKEND=x11 ./scripts/tauri-dev-linux.sh",
    "build:tauri": "tauri build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@milkdown/crepe": "^7.19.0",
    "@mui/material": "^7.3.9",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
